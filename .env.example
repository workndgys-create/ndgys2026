# ─────────────────────────────────────────────────────────────
# New Delhi Global Youth Summit 2026 — environment
# Copy to `.env` and fill in. Validated at boot by src/lib/env.ts
# ─────────────────────────────────────────────────────────────

# Database (PostgreSQL) — required
DATABASE_URL="postgresql://postgres.uijsfxxuccwyspmvvygv:Ndgys@database@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.uijsfxxuccwyspmvvygv:Ndgys@database@aws-1-ap-south-1.pooler.supabase.com:5432/postgres"
# Auth — required. Use a long random string (e.g. `openssl rand -base64 32`)
JWT_SECRET="replace-with-a-long-random-secret-min-16-chars"

# Public base URL — used for QR verify links, sitemap, magic links
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ── Resend (transactional email) ─────────────────────────────
# Get a key at https://resend.com. If unset, email is logged & skipped (dev-safe).
RESEND_API_KEY="re_xxxxxxxx"
# Must be an address on a domain you've VERIFIED in Resend.
# The resend.dev sandbox only delivers to your own account email.
MAIL_FROM="New Delhi Global Youth Summit <no-reply@yourdomain.com>"
# Where admin notifications (new registration / contact message) are sent.
MAIL_ADMIN_TO="team@yourdomain.com"

# ── Seed admin (used by `npm run db:seed`) ───────────────────
ADMIN_EMAIL="admin@nesummit.in"
ADMIN_PASSWORD="ChangeMe123!"

# ── Runtime feature flags (editable in Admin → Settings; these are defaults only) ──
NEXT_PUBLIC_HOME_PUBLISHED="true"      # show CMS sections (events/competitions/speakers/flow) on the home page
NEXT_PUBLIC_ALLOCATIONS_LIVE="false"   # show the live portfolio-allocations section
NEXT_PUBLIC_REGISTRATION_OPEN="true"   # accept new registrations
PORTFOLIO_HOLD_MINUTES="10"          # minutes a portfolio stays locked during checkout
EVENT_START="2026-08-22T09:00:00+05:30"   # used for the calendar (.ics) invite
EVENT_END="2026-08-23T17:30:00+05:30"
EVENT_VENUE="IIT Delhi, New Delhi"

# --- Cashfree payment gateway (see docs/CASHFREE.md) ---
CASHFREE_APP_ID=""                       # Cashfree App ID (client id)
CASHFREE_SECRET_KEY=""                   # Cashfree Secret Key
CASHFREE_MODE="sandbox"                  # sandbox | production
NEXT_PUBLIC_CASHFREE_MODE="sandbox"      # must match CASHFREE_MODE (used by the web SDK)
