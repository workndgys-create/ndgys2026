generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RegistrationStatus {
  PENDING
  PAID
  CANCELLED
}

enum AdminRole {
  SUPER_ADMIN
  DIRECTOR
  HR
  DEVELOPER
  FINANCE_LEAD
  FINANCE_EXECUTIVE
  DELEGATE_AFFAIRS_LEAD
  DELEGATE_AFFAIRS_EXECUTIVE
  VOLUNTEER_COORDINATOR
  VOLUNTEER
}

enum RegSource {
  online
  offline
}

enum AnnouncementAudience {
  ALL
  PAID
  TRACK
}

model Registration {
  id                String             @id @default(cuid())
  delegateId        String?            @unique
  fullName          String
  email             String
  phone             String
  institution       String?
  trackSlug         String
  trackName         String
  experience        String?
  amount            Int
  status            RegistrationStatus @default(PENDING)
  source            RegSource          @default(online)
  portfolio         String?
  portfolioId       String?
  delegationId      String?
  promoCode         String?
  nudgedAt          DateTime?
  cancelledAt       DateTime?
  rosterOptIn       Boolean  @default(true)
  age               Int?
  city              String?
  gender            String?
  emergencyContact  String?
  howHeard          String?
  notes             String?
  consentAccepted   Boolean  @default(false)
  guardianName      String?
  guardianPhone     String?
  guardianConsent   Boolean  @default(false)
  customAnswers     String?  // JSON array of { questionId, label, value } from the admin form builder
  dietary           String?
  accessibility     String?
  checkedInDay1     Boolean            @default(false)
  checkedInDay2     Boolean            @default(false)
  gatewayOrderId   String?            @unique
  gatewayPaymentId String?
  invoice           Invoice?
  photo             RegistrationPhoto?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([email])
  @@index([status])
  @@index([trackSlug])
}

model RegistrationPhoto {
  id             String       @id @default(cuid())
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  registrationId String       @unique
  mime           String
  data           Bytes
  createdAt      DateTime     @default(now())
}

model Invoice {
  id             String       @id @default(cuid())
  number         String       @unique
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  registrationId String       @unique
  amount         Int
  gstAmount      Int          @default(0)
  issuedAt       DateTime     @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  fullName  String
  email     String
  phone     String?
  subject   String
  message   String
  handled   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String
  role         AdminRole @default(VOLUNTEER)
  active            Boolean   @default(true)
  lastLoginAt       DateTime?
  extraPermissions  String?   // JSON string[] of granted action overrides
  deniedPermissions String?   // JSON string[] of denied action overrides
  createdAt         DateTime  @default(now())
}

model AdminAction {
  id         String   @id @default(cuid())
  adminEmail String
  action     String
  entity     String
  entityId   String?
  meta       String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

model Track {
  id         String   @id @default(cuid())
  slug       String   @unique
  name       String
  fee        Int
  capacity   Int      @default(40)
  agenda     String
  difficulty String   @default("Intermediate")
  isOpen     Boolean  @default(true)
  archived   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Speaker {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  title     String
  bio       String
  imageUrl  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model ScheduleItem {
  id        String   @id @default(cuid())
  day       Int
  startTime String
  endTime   String
  title     String
  trackSlug String?
  room      String?
  published Boolean  @default(true)
  order     Int      @default(0)
}

model Resource {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  level     String   @default("Beginner")
  body      String
  trackSlug String?
  createdAt DateTime @default(now())
}

model Announcement {
  id          String               @id @default(cuid())
  title       String
  body        String
  audience    AnnouncementAudience @default(ALL)
  trackSlug   String?
  publishedAt DateTime             @default(now())
}

model Waitlist {
  id         String    @id @default(cuid())
  name       String
  email      String
  trackSlug  String
  status     String    @default("WAITING") // WAITING | PROMOTED
  promotedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([trackSlug, status])
}

model MagicLinkToken {
  id        String    @id @default(cuid())
  email     String
  tokenHash String    @unique
  otpHash   String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
}

model Competition {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  category    String   @default("General")
  summary     String
  description String   @default("")
  prize       String?
  date        DateTime?
  ctaUrl      String?
  imageUrl    String?
  published   Boolean  @default(false)
  order       Int      @default(0)
  format          String   @default("SOLO") // SOLO | GROUP | BOTH
  minTeam         Int?
  maxTeam         Int?
  feeSolo         Int?     // rupees
  feeGroup        Int?     // rupees (per team)
  registrationOpen Boolean @default(true)
  questionsText    String?  // newline-separated custom questions for the entry form
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Event {
  id        String    @id @default(cuid())
  slug      String    @unique
  title     String
  kind      String    @default("keynote") // keynote | workshop | social | ceremony
  startsAt  DateTime?
  endsAt    DateTime?
  venue     String?
  summary   String
  imageUrl  String?
  published Boolean   @default(false)
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Portfolio {
  id         String    @id @default(cuid())
  trackSlug  String
  name       String
  order      Int       @default(0)
  status     String    @default("AVAILABLE") // AVAILABLE | HELD | ASSIGNED
  archived   Boolean   @default(false)
  heldUntil  DateTime?
  heldBy     String?   // Registration id currently holding it
  assignedTo String?   // Registration id it is assigned to (paid)
  createdAt  DateTime  @default(now())

  @@unique([trackSlug, name])
  @@index([trackSlug, status])
}

model CompetitionRegistration {
  id                String   @id @default(cuid())
  refId             String   @unique // NDGYS-C-2026-XXXX
  competitionId     String
  competitionTitle  String
  participation     String   // SOLO | GROUP
  teamName          String?
  leaderName        String
  email             String
  phone             String
  institution       String?
  members           String   @default("[]") // JSON array of { name, age? }
  teamSize          Int      @default(1)
  amount            Int      // rupees
  status            String   @default("PENDING")
  age               Int?
  city              String?
  gender            String?
  emergencyContact  String?
  howHeard          String?
  notes             String?
  pastExperience    String?
  answers           String?  // JSON array of { q, a } for the competition's custom questions
  consentAccepted   Boolean  @default(false)
  guardianName      String?
  guardianPhone     String?
  guardianConsent   Boolean  @default(false)
  gatewayOrderId   String?  @unique
  gatewayPaymentId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([competitionId, status])
}

model PromoCode {
  id         String    @id @default(cuid())
  code       String    @unique
  kind       String    @default("PERCENT") // PERCENT | FLAT
  value      Int       // percent (0-100) or rupees off
  maxUses    Int?
  uses       Int       @default(0)
  appliesTo  String?   // optional track slug filter; null = all committees
  active     Boolean   @default(true)
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
}

model Delegation {
  id                String   @id @default(cuid())
  schoolName        String
  headName          String
  email             String
  phone             String
  institution       String?
  memberCount       Int
  amount            Int      // total rupees (after discount)
  promoCode         String?
  consentAccepted   Boolean  @default(false)
  status            String   @default("PENDING") // PENDING | PAID | CANCELLED
  gatewayOrderId   String?  @unique
  gatewayPaymentId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model CommitteeGuide {
  id         String   @id @default(cuid())
  trackSlug  String
  title      String
  fileName   String
  mime       String   @default("application/pdf")
  sizeBytes  Int      @default(0)
  data       Bytes
  uploadedBy String?
  uploadedAt DateTime @default(now())

  @@index([trackSlug])
}

model BackgroundGuide {
  id            String    @id @default(cuid())
  title         String
  trackSlug     String?   // null = all MUN delegates; else a specific committee
  fileName      String
  mime          String    @default("application/pdf")
  sizeBytes     Int       @default(0)
  data          Bytes
  notifiedCount Int       @default(0)
  notifiedAt    DateTime?
  uploadedBy    String?
  uploadedAt    DateTime  @default(now())

  @@index([trackSlug])
}

model SecretariatMember {
  id        String   @id @default(cuid())
  name      String
  role      String
  photoUrl  String?
  bio       String?
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Sponsor {
  id         String   @id @default(cuid())
  name       String
  logoUrl    String?
  websiteUrl String?
  tier       String?  // e.g. Title, Gold, Partner, Community
  order      Int      @default(0)
  published  Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model AccommodationOption {
  id          String   @id @default(cuid())
  name        String
  kind        String   @default("Hotel") // Hotel | Travel | Nearby
  description String
  address     String?
  distance    String?  // e.g. "1.2 km from venue"
  priceRange  String?  // e.g. "Rs 3,000-5,000 / night"
  url         String?
  imageUrl    String?
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model RegistrationQuestion {
  id        String   @id @default(cuid())
  label     String
  type      String   @default("short") // short | paragraph | select | multiselect
  options   String?  // JSON array of option strings (for select/multiselect)
  helpText  String?
  required  Boolean  @default(false)
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
}
