    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "jimp": "^1.6.1",
    "jsdom": "^24.1.1",
    "postcss": "^8.4.40",
    "prisma": "^7.8.0",
    "tailwindcss": "^3.4.7",
    "tsx": "^4.22.4",
    "typescript": "5.9.3",
    "vitest": "^2.0.5"
