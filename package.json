    "bcryptjs": "^2.4.3",
    "dotenv": "^17.4.2",
    "jose": "^5.6.3",
    "next": "^14.2.35",
    "pdfkit": "^0.15.0",
    "pg": "^8.21.0",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^4.0.1",
    "sharp": "^0.34.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.46.0",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.0",
